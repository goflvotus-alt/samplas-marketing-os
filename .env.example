# SAMPLAS Marketing OS
# 실제 토큰은 이 파일이 아니라 .env 파일에 넣으세요.

META_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=361113897317760
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841400194524814
SAMPLAS_INSTAGRAM_USERNAME=samplaskr
GRAPH_VERSION=v25.0
HOST=127.0.0.1
PORT=8787
REPORT_TIMEZONE=Asia/Seoul

# Local default:
# WORK_DIR=./work
#
# Render Free temporary path:
# WORK_DIR=/tmp/samplas-dashboard/work
#
# Render paid disk path:
# WORK_DIR=/var/data/samplas-dashboard/work
WORK_DIR=

# Later
# Meta Ads: Meta Business Settings에서 광고 계정 ID를 확인하세요. 형식은 act_숫자 입니다.
# 같은 META_ACCESS_TOKEN에 ads_read 권한이 포함되어야 합니다.
META_AD_ACCOUNT_ID=act_

# Cafe24: Cafe24 Developers 앱에서 Admin API 주문 조회 권한을 켜고 OAuth 토큰을 발급하세요.
CAFE24_MALL_ID=
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_ACCESS_TOKEN=
CAFE24_REFRESH_TOKEN=
CAFE24_ACCESS_TOKEN_EXPIRES_AT=
CAFE24_REDIRECT_URI=http://127.0.0.1:8787/api/cafe24/oauth/callback
# Cafe24 앱에서 필요한 scope를 직접 지정해야 하면 여기에 입력하세요.
# 예: CAFE24_SCOPES=mall.read_order
CAFE24_SCOPES=

# Recommended local setup: keep Cafe24 token ownership on Render and let local read Cafe24 through Render.
# If this is set, local /api/cafe24/orders calls the Render dashboard instead of using local Cafe24 tokens.
CAFE24_PROXY_BASE_URL=https://samplas-marketing-os.onrender.com
CAFE24_PROXY_ORDERS_PATH=/api/cafe24/orders
CAFE24_PROXY_SECRET=
# Render 앱이 Basic Auth로 보호되어 있으면 username:password 형식으로 입력하세요.
CAFE24_PROXY_BASIC_AUTH=

# Render CSV import protection.
# Set at least one of these on Render before using /api/cafe24/csv/import.
# CAFE24_PROXY_SECRET is used as x-samplas-internal-token.
# CAFE24_PROXY_BASIC_AUTH is used as Basic username:password.

# Naver Search Ads API
# Needed later for SAMPLAS NAVER ADS REPORT and KPI HUB.
NAVER_ADS_API_KEY=
NAVER_ADS_SECRET_KEY=
NAVER_ADS_CUSTOMER_ID=
NAVER_ADS_BASE_URL=https://api.searchad.naver.com
